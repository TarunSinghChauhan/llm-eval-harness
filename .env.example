# ─── LLM API Keys ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── LangSmith (free at smith.langchain.com) ─────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=llm-eval-harness

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://eval_user:eval_pass@localhost:5432/eval_db

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── MLflow ──────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=llm-eval-harness

# ─── Eval Settings ───────────────────────────────────────────────────────────
EVAL_BATCH_SIZE=10
EVAL_MAX_CONCURRENT=5
BOOTSTRAP_ITERATIONS=1000
REGRESSION_THRESHOLD=0.02

# ─── Alerting (optional) ─────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
